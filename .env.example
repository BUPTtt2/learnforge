# LearnForge 环境配置文件
# 请将实际API Key填入对应位置（不要提交到Git！）
# 复制此文件为 .env 并填入真实密钥

# ==================== 云端API配置 ====================

# ModelScope API (DeepSeek-V3.2)
# 申请地址：https://modelscope.cn
MODELSCOPE_API_KEY=your_modelscope_api_key_here
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1

# 百度云 API
# 申请地址：https://console.baidubce.com
BAIDU_CLOUD_API_KEY=your_baidu_cloud_api_key_here

# Groq API (备用)
# 申请地址：https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# 火山引擎 API
# 申请地址：https://www.volcengine.com
VOLCENGINE_API_KEY=your_volcengine_api_key_here

# Tavily API (外部搜索)
# 申请地址：https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ==================== 本地模型配置 ====================

# Ollama 配置
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

# 默认使用的本地模型
DEFAULT_LOCAL_MODEL=qwen2.5:7b
FAST_LOCAL_MODEL=qwen3:4b

# ==================== 应用配置 ====================

# Flask 配置
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=True

# 前端配置
FRONTEND_URL=http://localhost:3000

# ==================== 功能开关 ====================

# 是否启用云端模型（重要任务使用）
ENABLE_CLOUD_MODEL=True

# 是否启用RAG
ENABLE_RAG=False

# 是否启用多模态
ENABLE_MULTIMODAL=True

# 是否启用异步生成
ENABLE_ASYNC=True