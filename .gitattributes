# Auto detect text files and perform LF normalization
* text=auto

# Python files
*.py text=auto eol=lf

# JavaScript/JSX files
*.js text=auto eol=lf
*.jsx text=auto eol=lf

# Markdown files
*.md text=auto eol=lf

# JSON files
*.json text=auto eol=lf

# YAML files
*.yaml text=auto eol=lf
*.yml text=auto eol=lf

# Configuration files
*.env text=auto eol=lf
*.ini text=auto eol=lf
*.cfg text=auto eol=lf

# CSS files
*.css text=auto eol=lf

# HTML files
*.html text=auto eol=lf

# Binary files
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.safetensors binary
*.bin binary
*.gguf binary